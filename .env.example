# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Mode of Operation
# Choose one of the following:
# - 'german_only'               : Posts German news to TELEGRAM_CHANNEL_ID_DE (or TELEGRAM_CHANNEL_ID)
# - 'english_only'              : Posts English news to TELEGRAM_CHANNEL_ID_EN (or TELEGRAM_CHANNEL_ID)
# - 'bilingual_single_channel'  : Posts German and English news (as 2 separate messages) to TELEGRAM_CHANNEL_ID
# - 'two_channels'              : Posts German news to TELEGRAM_CHANNEL_ID_DE AND English news to TELEGRAM_CHANNEL_ID_EN
BOT_MODE=german_only

# Default or legacy channel ID
TELEGRAM_CHANNEL_ID=@your_general_channel

# Language-specific channel IDs (if using 'two_channels' or 'german_only'/'english_only')
# If left blank, they will fall back to using TELEGRAM_CHANNEL_ID
TELEGRAM_CHANNEL_ID_DE=@your_german_channel
TELEGRAM_CHANNEL_ID_EN=@your_english_channel

# Gemini API Configuration (Get your API Key from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
